            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"evento\": \"pago_expirado\",\n  \"cita_id\": \"{{ $json.cita_id }}\",\n  \"cliente_id\": \"{{ $json.cliente_id }}\",\n  \"telefono\": \"{{ $json.telefono }}\",\n  \"nombre\": \"{{ $json.nombre }}\",\n  \"fecha_cita\": \"{{ $json.fecha_hora }}\",\n  \"monto_anticipo\": {{ $json.monto }},\n  \"link_pago\": \"{{ $json.link }}\"\n}",
        "options": {}
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Notificar cita cancelada",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 200]
